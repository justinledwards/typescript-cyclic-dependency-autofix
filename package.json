{
  "name": "typescript-cyclic-dependency-autofix",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently --names frontend,backend --prefix-colors cyan,yellow \"vite dev --port 3000\" \"tsx watch backend/server.ts\"",
    "dev:frontend": "vite dev --port 3000",
    "dev:backend": "tsx watch backend/server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "eslint . && biome check .",
    "lint:fix": "eslint --fix . && biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write . && eslint --fix . && pnpm run test:coverage",
    "scan": "tsx cli/index.ts scan",
    "explain": "tsx cli/index.ts explain",
    "mine:repo-history": "tsx cli/index.ts mine:repo-history",
    "scan:all": "tsx cli/index.ts scan:all",
    "retry:failed": "tsx cli/index.ts retry:failed",
    "create:pr": "tsx cli/index.ts create:pr",
    "export:patches": "tsx cli/index.ts export:patches",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "dependency-cruiser": "^17.3.9",
    "fastify": "^5.8.2",
    "jscodeshift": "^17.3.0",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recast": "^0.23.11",
    "simple-git": "^3.28.0",
    "tailwindcss": "^4.1.18",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jscodeshift": "^0.12.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.3",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "better-sqlite3"
    ],
    "ignoredBuiltDependencies": [
      "better-sqlite3@12.8.0"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write",
      "eslint --fix"
    ],
    "*.{json,css}": [
      "biome format --write"
    ]
  }
}
